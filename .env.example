# Discord and Slack Webhook URLs (leave empty to log alert payloads to stdout)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/here

# Threshold for sending alerts: DEBUG, INFO, WARNING, ERROR, CRITICAL
ALERT_SEVERITY_LEVEL=ERROR

# Path to the server log file to watch
LOG_FILE_PATH=logs/server.log

# Deduplication rate-limiting window (in seconds)
THROTTLE_WINDOW_SECONDS=60

# Interval for the log generator to write logs (in seconds)
LOG_INTERVAL_SECONDS=2
